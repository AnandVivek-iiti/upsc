
# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get this from: Atlas → your cluster → Connect → Drivers
# Replace <username>, <password>, <cluster>, <dbname>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── Google Gemini ─────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_key_here

# ── CORS (optional override) ──────────────────────────────────
# Allowed origins are hardcoded in server.js.
# Add your production frontend URL there if it changes.
# FRONTEND_URL=https://upsc-by-iitian.onrender.com
